PORT=3000
NODE_ENV=development

# Supabase 项目设置 > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 至少 32 位随机字符串，正式环境必须修改
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# 首次启动时自动创建/更新管理员账号
ADMIN_PHONE=13800138000
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=老板

# 可选：固定商品分享链接的域名。留空时自动使用当前访问域名
# PUBLIC_BASE_URL=https://wholesale-ordering-system.onrender.com

# 可选：Supabase Storage 图片桶名称。migration-v3.sql 默认创建 product-images
SUPABASE_IMAGE_BUCKET=product-images

# 可选：限制跨域来源。多个来源用英文逗号分隔；留空表示同源及全部来源
CORS_ORIGINS=
